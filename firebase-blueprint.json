{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "streak": { "type": "number" },
        "lastActive": { "type": "string", "format": "date-time" },
        "goals": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email"]
    },
    "Note": {
      "title": "Note",
      "description": "AI summarized notes from PDF or text",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "summary": { "type": "string" },
        "keyPoints": { "type": "array", "items": { "type": "string" } },
        "flashcards": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title"]
    },
    "Task": {
      "title": "Task",
      "description": "Daily study tasks",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "completed": { "type": "boolean" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["userId", "title"]
    },
    "Quiz": {
      "title": "Quiz",
      "description": "Generated quiz results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "topic": { "type": "string" },
        "score": { "type": "number" },
        "total": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "topic", "score"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "AI summarized notes"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "User study tasks"
    },
    "/quizzes/{quizId}": {
      "schema": "Quiz",
      "description": "Quiz performance results"
    }
  }
}
